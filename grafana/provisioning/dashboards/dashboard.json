  "panels": [
    {
      "title": "Taxa de Requisições (RPS)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum(rate(http_requests_total[1m])) by (endpoint)", "legendFormat": "{{endpoint}}" }
      ]
    },
    {
      "title": "Latência p95 (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[1m])) by (le, endpoint)) * 1000", "legendFormat": "{{endpoint}}" }
      ]
    },
    {
      "title": "Saúde do Cache (Hit/Miss/Fallback)",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "targets": [
        { "expr": "sum(cache_operations_total) by (result)", "legendFormat": "{{result}}" }
      ]
    }
  ],
